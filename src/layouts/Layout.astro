---
// Layout component for the landing page
import "../styles/landing.css";
import GA from "../content/custom/ga.astro";
import Fonts from "../components/Fonts.astro";
import DocsLanguageClient from "../components/DocsLanguageClient.astro";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="description" content="Open-source framework for building AI-powered apps with unified APIs for Google Gemini, GPT, Claude, and more. Built-in developer tools, structured outputs, tool calling, and production monitoring. Deploy anywhere.">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Genkit - Open-source AI framework by Google in JavaScript, Go and Python</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="sitemap" href="/sitemap-index.xml" />
  <Fonts />
  <DocsLanguageClient />
</head>


<body class="bg-landing bg-landing-gradient text-foreground font-sans min-h-screen m-0 p-0">
  <slot />
  <GA bannerForceDarkMode={true} />
</body>
</html>

