import Resources from "../components/landing/Resources.astro";
import CallToAction from "../components/landing/CallToAction.astro";
import Footer from "../components/landing/Footer.astro";
---

<Layout>
  <nav class="sticky top-0 z-30 h-16 px-6 bg-genkit-nav">
    <Header />
  </nav>
  <Hero />
  <LanguageSelector />
  <Features />
  <DeveloperTools />
  <Examples />
  <Resources />
