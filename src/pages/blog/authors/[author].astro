---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Icon from '../../../components/landing/Icon.astro';
import authorsData from '../../../data/authors.json';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const paths = [];
  for (const [key, author] of Object.entries(authorsData)) {
    const lower = author.slug.toLowerCase();
    const upper = author.slug.toUpperCase();
    const title = author.slug.split('-').map(s => s.charAt(0).toUpperCase() + s.slice(1).toLowerCase()).join('-');

    const casings = new Set([lower, upper, title]);
    for (const slug of casings) {
      paths.push({
        params: { author: slug },
        props: { authorId: key, authorData: author }
      });
    }
  }
  return paths;
}

const { authorId, authorData } = Astro.props;

// Fetch all docs and filter for blog posts authored by this author
const allDocs = await getCollection('docs');
const authorPosts = allDocs.filter(entry => {
  if (!entry.id.startsWith('blog/') || entry.id.includes('README') || !entry.data.date) return false;
  const a = entry.data.authors;
  if (!a) return false;
  if (typeof a === 'string') return a.toLowerCase() === authorId.toLowerCase() || a.toLowerCase() === authorData.name.toLowerCase();
  if (Array.isArray(a)) return a.some(item => typeof item === 'string' ? item.toLowerCase() === authorId.toLowerCase() || item.toLowerCase() === authorData.name.toLowerCase() : (item as any)?.name?.toLowerCase() === authorData.name.toLowerCase());
  if (typeof a === 'object') return (a as any).name?.toLowerCase() === authorData.name.toLowerCase();
  return false;
}).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<StarlightPage frontmatter={{ title: authorData.name, pagefind: false }}>
  <div class="author-social-card not-content">
    {(authorData as any).image ? (
      <img src={(authorData as any).image} alt={authorData.name} class="author-avatar-img" />
    ) : (
      <div class="author-avatar-circle">
        <span>{authorData.name.split(' ').map((n: string) => n[0]).join('')}</span>
      </div>
    )}
    <div class="author-info-col">
      <h1 class="author-heading">{authorData.name}</h1>
      {authorData.title && <p class="author-subheading">{authorData.title}</p>}
      {authorData.socials && (
        <div class="socials-row">
          {Object.entries(authorData.socials).map(([net, url]) => (
            <a href={url as string} target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label={net}>
              <Icon name={net as any} size="sm" />
            </a>
          ))}
        </div>
      )}
    </div>
  </div>

  <div class="posts-list not-content">
    <div class="posts-count">
      {authorPosts.length} {authorPosts.length === 1 ? 'post' : 'posts'} by {authorData.name}
    </div>
    {authorPosts.map(post => {
      const postUrl = `/blog/${post.id.replace(/^blog\//, '')}`;
      const dateStr = new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
      return (
        <article class="preview">
          <header>
            <h2>
              <a href={postUrl}>{post.data.title}</a>
            </h2>
            <div class="metadata">
              <div class="dates">
                <time datetime={new Date(post.data.date).toISOString()}>{dateStr}</time>
              </div>
              <div class="authors">
                <span class="author-label">{authorData.name}</span>
              </div>
            </div>
          </header>
          <div class="sl-markdown-content">
            <p>{post.data.description}</p>
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <footer>
              <div class="tags-container">
                <b>Tags:</b>
                <ul class="tags-ul">
                  {post.data.tags.map((tag: string) => (
                    <li class="tag-li">
                      <a href={`/blog/tags/${tag}`} class="tag-a">{tag}</a>
                    </li>
                  ))}
                </ul>
              </div>
            </footer>
          )}
        </article>
      );
    })}
  </div>
</StarlightPage>

<style>
  :global([data-has-toc] :is(.right-sidebar-panel, mobile-starlight-toc)) {
    display: none !important;
  }

  :global([data-has-toc] .main-frame) {
    padding-top: var(--sl-nav-height);
  }

  .author-social-card {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 2rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 16px;
    margin-bottom: 3rem;
    box-shadow: var(--sl-shadow-lg);
  }

  @media (max-width: 640px) {
    .author-social-card {
      flex-direction: column;
      text-align: center;
      gap: 1.25rem;
      padding: 1.5rem;
    }
  }

  .author-avatar-img {
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--sl-color-hairline);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .author-avatar-circle {
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #22d3ee 0%, #34d399 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-size: 2.25rem;
    font-weight: 700;
    font-family: "Google Sans";
    flex-shrink: 0;
    box-shadow: 0 4px 20px rgba(34, 211, 238, 0.25);
  }

  [data-theme="light"] .author-avatar-circle {
    background: linear-gradient(135deg, #0891b2 0%, #059669 100%);
  }

  .author-info-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  @media (max-width: 640px) {
    .author-info-col {
      align-items: center;
    }
  }

  .author-heading {
    font-size: 2.25rem !important;
    font-weight: 700 !important;
    font-family: "Google Sans" !important;
    color: var(--sl-color-white);
    margin: 0 !important;
    line-height: 1.2 !important;
  }

  [data-theme="light"] .author-heading {
    color: var(--sl-color-black);
  }

  .author-subheading {
    font-size: 1.05rem;
    color: var(--sl-color-gray-3);
    margin: 0;
    font-weight: 400;
  }

  .socials-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .social-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 10px;
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-gray-3);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .social-icon-btn:hover {
    color: #22d3ee;
    border-color: #22d3ee;
    background: rgba(34, 211, 238, 0.1);
    transform: translateY(-2px);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .posts-count {
    font-size: 1.1rem;
    color: var(--sl-color-gray-3);
    margin-bottom: -1rem;
  }

  .preview {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    padding-bottom: 3rem;
  }

  .preview:last-child {
    border-bottom: none;
  }

  .preview h2 {
    font-family: "Google Sans";
    margin-bottom: 0.5rem !important;
  }

  .preview h2 a {
    text-decoration: none;
    color: var(--sl-color-text);
  }

  .preview h2 a:hover {
    color: var(--sl-color-text-accent);
  }

  .metadata {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
  }

  .author-label {
    color: var(--sl-color-text-accent);
    font-weight: 500;
  }

  .sl-markdown-content p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
  }

  .tags-container {
    font-size: var(--sl-text-sm);
  }

  .tags-ul {
    display: inline;
    margin-inline-start: 0.25rem;
    padding: 0;
  }

  .tag-li {
    display: inline-block;
    margin-bottom: 0.25rem;
    padding: 0;
  }

  .tag-a {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.3rem;
    font-size: var(--sl-text-sm);
    margin-inline: 0.2rem;
    padding: 0.25rem 0.5rem 0.35rem;
    text-decoration: none;
    color: var(--sl-color-gray-3);
  }

  .tag-a:hover {
    border-color: var(--sl-color-gray-2);
    color: var(--sl-color-text);
  }
</style>
