---
import config from "virtual:starlight/user-config";
import LanguageSelect from "virtual:starlight/components/LanguageSelect";
import Search from "virtual:starlight/components/Search";
import SiteTitle from "virtual:starlight/components/SiteTitle";
import SocialIcons from "virtual:starlight/components/SocialIcons";
import ThemeSelect from "virtual:starlight/components/ThemeSelect";
import GA from './ga.astro';

/**
 * Render the `Search` component if Pagefind is enabled or the default search component has been overridden.
 */
const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== "@astrojs/starlight/components/Search.astro";
---

<GA/>

<div class="header">
  <div class="sl-flex left-group">
    <div class="title-wrapper">
      <SiteTitle />
    </div>
    <a
      class="nav-link print:hidden"
      href="/docs/get-started"
      aria-current={Astro.url.pathname.startsWith('/docs') ? 'page' : undefined}
    >
      Docs
    </a>
    <a
      class="nav-link print:hidden"
      href="/blog"
      aria-current={Astro.url.pathname.replace(/\/$/, '') === '/blog' ||
      Astro.url.pathname.startsWith('/blog/')
        ? 'page'
        : undefined}
    >
      Blog
    </a>
  </div>
  <div class="sl-flex print:hidden right-group">
    {shouldRenderSearch && <Search />}
    <div class="sl-hidden md:sl-flex social-icons">
      <SocialIcons />
    </div>
    <div class="sl-hidden md:sl-flex">
      <ThemeSelect />
    </div>
    <div class="sl-hidden md:sl-flex">
      <LanguageSelect />
    </div>
  </div>
</div>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      display: flex;
      align-items: center;
      /* Prevent long titles overflowing and covering the search and menu buttons on narrow viewports. */
      overflow: clip;
      /* Avoid clipping focus ring around link inside title wrapper. */
      padding: 0.25rem;
      margin: -0.25rem;
      flex-shrink: 0;
    }

    .right-group,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }

    .left-group {
      align-items: center;
      gap: 0.5rem;
      flex-shrink: 0;
    }

    @media (min-width: 50rem) {
      .left-group {
        gap: 2rem;
      }
    }

    .nav-link {
      display: inline-flex;
      align-items: center;
      /* Match the sidebar nav column headers (.group-label .large). */
      font-family: "Google Sans";
      font-size: var(--sl-text-base);
      font-weight: 500;
      color: var(--sl-color-text);
      text-decoration: none;
      white-space: nowrap;
    }

    .nav-link:hover {
      color: var(--sl-color-white);
    }

    .nav-link[aria-current="page"] {
      color: var(--sl-color-text-accent);
    }

    .search-wrapper {
      align-items: center;
    }

    .social-icons::after {
      content: "";
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }

    .mobile-search {
      align-items: center;
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
                var(--sl-content-width)
            ) / 2
        );
        display: grid;
        grid-template-columns:
          /* 1 (site title): takes needed space */
          auto
          /* 2 (spacer): fills remaining space to push right-group to the end */
          1fr
          /* 3 (right items): search + social icons + theme select */
          auto;
        align-content: center;
      }
    }
  }
</style>
