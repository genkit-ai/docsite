---
/**
 * Starlight `Hero` component override.
 *
 * Registered via `astro.config.mjs` (`components.Hero`). Used by any page that
 * declares a `hero:` block in its frontmatter — currently `docs/overview.mdx`
 * and `404.md`.
 *
 * Differs from Starlight's default Hero in that it intentionally does NOT
 * render the page `title` as an `<h1>` (the long SEO title would otherwise
 * dominate the page). Only the tagline, image, and action buttons are shown.
 */
import { Image } from 'astro:assets';
import { LinkButton } from '@astrojs/starlight/components';

/**
 * Mirrors the per-action shape produced by Starlight's hero zod schema
 * (`@astrojs/starlight/schemas/hero.ts`). Kept local to avoid reaching into
 * Starlight internals; update if Starlight's schema ever changes.
 */
type HeroAction = {
	text: string;
	link: string;
	variant?: 'primary' | 'secondary' | 'minimal';
	icon?: { name?: string; html?: string };
	attrs?: Record<string, string | number | boolean>;
};

const { data } = Astro.locals.starlightRoute.entry;
const { tagline, image, actions } = data.hero || {};

const imageAttrs = {
	loading: 'eager' as const,
	decoding: 'async' as const,
	width: 400,
	alt: image?.alt || '',
};

let darkImage: ImageMetadata | undefined;
let lightImage: ImageMetadata | undefined;
if (image) {
	if ('file' in image) {
		darkImage = image.file;
	} else if ('dark' in image) {
		darkImage = image.dark;
		lightImage = image.light;
	}
}

/* Tailwind v4 trailing-`!` important is needed to override the inline */
/* dimensions Astro's <Image> component emits from the `width` attribute. */
const imageClass = 'm-10! h-auto! w-[300px]!';
---

<div class="flex flex-col items-center gap-4 pb-[90px]">
	{
		darkImage && (
			<Image
				src={darkImage}
				{...imageAttrs}
				class:list={[imageClass, { 'light:sl-hidden': Boolean(lightImage) }]}
			/>
		)
	}
	{lightImage && <Image src={lightImage} {...imageAttrs} class:list={['dark:sl-hidden', imageClass]} />}
	<div class="flex flex-col text-center md:text-start">
		<div class="flex flex-col items-center gap-4 md:items-start">
			{
				tagline && (
					<div
						class="max-w-[50ch] text-center text-base text-muted md:text-xl"
						set:html={tagline}
					/>
				)
			}
		</div>
		<div class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
			{
				actions && actions.map(({ icon, link: href, text, variant, attrs }: HeroAction) => (
					<LinkButton {href} {variant} icon={icon?.name as any} class:list={attrs as any}>
						{text}
					</LinkButton>
				))
			}
		</div>
	</div>
</div>

<style>
	.link-text {
		font-size: 20px !important;
		line-height: 100% !important;
	}

	.github-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		font-size: 20px;
		font-weight: 500;
		line-height: 100%;
		transition: color 0.2s ease;
	}

	.github-link:hover {
		color: var(--sl-color-white);
	}
</style>
