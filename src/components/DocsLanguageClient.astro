---
interface Props {
  docLanguageSupportByPath?: Record<string, string[]>;
  docLanguageAgnosticByPath?: Record<string, boolean>;
}

const {
  docLanguageSupportByPath = {},
  docLanguageAgnosticByPath = {},
} = Astro.props;

const hasDocConfig =
  Object.keys(docLanguageSupportByPath).length > 0 ||
  Object.keys(docLanguageAgnosticByPath).length > 0;
---

{
  hasDocConfig && (
    <script
      is:inline
      id="genkit-doc-language-config"
      type="application/json"
      set:html={JSON.stringify({
        docLanguageSupport: docLanguageSupportByPath,
        docLanguageAgnostic: docLanguageAgnosticByPath,
      })}
    />
  )
}

<script>
  import { initUnifiedPageManager } from '../scripts/unified-page-manager.ts';

  const configEl = document.getElementById('genkit-doc-language-config');
  const config = configEl ? JSON.parse(configEl.textContent || '{}') : {};

  initUnifiedPageManager({
    docLanguageSupport: config.docLanguageSupport ?? {},
    docLanguageAgnostic: config.docLanguageAgnostic ?? {},
  });
</script>
