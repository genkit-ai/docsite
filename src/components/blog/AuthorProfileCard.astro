---
import Icon from '../landing/Icon.astro';
import authorsData from '../../data/authors.json';

interface Props {
  authorSlug: string;
}

const { authorSlug } = Astro.props;
const authorInfo = (authorsData as any)[authorSlug.toLowerCase()] || null;

if (!authorInfo) return null;
---

<div class="author-social-banner not-content">
  {authorInfo.image ? (
    <img src={authorInfo.image} alt={authorInfo.name} class="author-avatar-img" />
  ) : (
    <div class="author-avatar-circle">
      <span>{authorInfo.name.split(' ').map((n: string) => n[0]).join('')}</span>
    </div>
  )}
  <div class="author-info-col">
    <div class="author-banner-name">{authorInfo.name}</div>
    {authorInfo.title && <div class="author-banner-title">{authorInfo.title}</div>}
    {authorInfo.socials && Object.keys(authorInfo.socials).length > 0 && (
      <div class="socials-row">
        {Object.entries(authorInfo.socials).map(([net, url]) => (
          <a href={url as string} target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label={net}>
            <Icon name={net as any} size="sm" />
          </a>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .author-social-banner {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 2rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 16px;
    margin-top: 1.5rem;
    margin-bottom: 2.5rem;
    box-shadow: var(--sl-shadow-lg);
  }

  @media (max-width: 40rem) {
    .author-social-banner {
      flex-direction: column;
      text-align: center;
      gap: 1.25rem;
      padding: 1.5rem;
    }
  }

  .author-avatar-img {
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--sl-color-hairline);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .author-avatar-circle {
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #22d3ee 0%, #34d399 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-size: 2.25rem;
    font-weight: 700;
    font-family: "Google Sans";
    flex-shrink: 0;
    box-shadow: 0 4px 20px rgba(34, 211, 238, 0.25);
  }

  [data-theme="light"] .author-avatar-circle {
    background: linear-gradient(135deg, #0891b2 0%, #059669 100%);
  }

  .author-info-col {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  @media (max-width: 40rem) {
    .author-info-col {
      align-items: center;
    }
  }

  .author-banner-name {
    font-size: 1.75rem;
    font-weight: 700;
    font-family: "Google Sans";
    color: var(--sl-color-white);
    line-height: 1.2;
  }

  [data-theme="light"] .author-banner-name {
    color: var(--sl-color-black);
  }

  .author-banner-title {
    font-size: 1rem;
    color: var(--sl-color-gray-3);
  }

  .socials-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .social-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 10px;
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-gray-3);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none !important;
  }

  .social-icon-btn:hover {
    color: #22d3ee;
    border-color: #22d3ee;
    background: rgba(34, 211, 238, 0.1);
    transform: translateY(-2px);
  }
</style>
