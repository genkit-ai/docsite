---
export interface Props {
  framework: string;
  title: string;
  description?: string;
  href: string;
}

const { framework, title, description, href } = Astro.props;

type IconDef = { file: string; color?: string; multiColor?: boolean };

const ICONS: Record<string, IconDef> = {
  typescript: { file: 'typescript', color: '#3178c6' },
  go: { file: 'go', color: '#00add8' },
  dart: { file: 'dart', color: '#0175c2' },
  python: { file: 'python', color: '#3776ab' },
  nextjs: { file: 'nextdotjs', color: 'var(--sl-color-white)' },
  sveltekit: { file: 'svelte', color: '#ff3e00' },
  nuxt: { file: 'nuxt', color: '#00dc82' },
  'tanstack-start': { file: 'tanstack', color: '#ff4154' },
  astro: { file: 'astro', color: '#bc52ee' },
  angular: { file: 'angular', color: '#dd0031' },
  react: { file: 'react', color: '#61dafb' },
  remix: { file: 'remix', color: 'var(--sl-color-white)' },
  express: { file: 'express', color: 'var(--sl-color-white)' },
  hono: { file: 'hono', color: '#e36002' },
  fastify: { file: 'fastify', color: 'var(--sl-color-white)' },
  nestjs: { file: 'nestjs', color: '#e0234e' },
  gin: { file: 'gin', multiColor: true },
  echo: { file: 'echo', multiColor: true },
  chi: { file: 'chi', multiColor: true },
  nethttp: { file: 'go', color: '#00add8' },
  fastapi: { file: 'fastapi', color: '#009688' },
  flask: { file: 'flask', color: 'var(--sl-color-white)' },
  django: { file: 'django', color: '#0c4b33' },
  flutter: { file: 'flutter', color: '#02569b' },
  shelf: { file: 'shelf', color: '#0175c2' },
};

const icon = ICONS[framework];
const iconUrl = icon ? `/assets/framework-icons/${icon.file}.svg` : null;
const iconColor = icon?.color ?? 'currentColor';
const multiColor = icon?.multiColor === true;
---

<a
  class="framework-card"
  href={href}
  style={iconUrl && !multiColor ? `--icon-url: url('${iconUrl}'); --icon-color: ${iconColor};` : undefined}
>
  {iconUrl && multiColor && <img class="icon icon-img" src={iconUrl} alt="" aria-hidden="true" />}
  {iconUrl && !multiColor && <span class="icon icon-mask" aria-hidden="true"></span>}
  <span class="text">
    <span class="title">{title}</span>
    {description && <span class="description">{description}</span>}
  </span>
</a>

<style>
  .framework-card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease,
      transform 0.15s ease;
  }

  .framework-card:hover {
    border-color: var(--sl-color-gray-2);
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }

  .icon {
    display: block;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
  }

  .icon-mask {
    background-color: var(--icon-color);
    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }

  .icon-img {
    object-fit: contain;
    object-position: center;
  }

  .text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .title {
    color: var(--sl-color-white);
    font-weight: 600;
    font-size: var(--sl-text-base);
    line-height: var(--sl-line-height-headings);
  }

  .description {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
    line-height: 1.5;
  }
</style>
