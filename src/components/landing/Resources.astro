---
import Icon from './Icon.astro';
import Link from './Link.astro';

type ResourceCard = {
  title: string;
  description: string;
  href: string;
  icon: "document" | "github" | "discord";
  ctaText: string;
};

const resourceCards: ResourceCard[] = [
  {
    title: "Docs",
    description: "Developer guide, API reference, tutorials",
    href: "/docs/get-started",
    icon: "document",
    ctaText: "Read docs"
  },
  {
    title: "GitHub",
    description: "Source code, file issues", 
    href: "https://github.com/genkit-ai/genkit",
    icon: "github",
    ctaText: "View repository"
  },
  {
    title: "Discord",
    description: "Join the community, ask questions, share your work", 
    href: "https://discord.gg/qXt5zzQKpc",
    icon: "discord",
    ctaText: "Join us"
  }
];

---

<section class="pt-4 sm:pt-6 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid sm:grid-cols-3 gap-3 sm:gap-6 mx-auto">
      {resourceCards.map((card) => (
        <div class="rounded-xl p-4 sm:p-6 flex items-start gap-3 sm:gap-6 bg-genkit-nav border border-border-muted h-full">
          <div class="rounded-xl p-3 sm:p-6 bg-genkit-icon shrink-0">
            <Icon name={card.icon} size="md" class="text-muted w-6 h-6 sm:w-8 sm:h-8" />
          </div>
          <div class="flex flex-col min-w-0 h-full">
            <h3 class="text-lg font-semibold text-muted mb-1 sm:mb-2 flex items-center gap-2">
              {card.title}
              {card.title === 'GitHub' && (
                <Icon name="github" size="sm" class="text-muted" />
              )}
            </h3>
            <p class="text-sm leading-normal text-muted mb-3 sm:mb-4 grow">
              {card.description}
            </p>
            <Link variant="card" href={card.href}>
              {card.ctaText}
            </Link>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
