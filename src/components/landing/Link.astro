---
type LinkVariant = 'card' | 'footer' | 'nav';

interface Props {
  variant: LinkVariant;
  href: string;
  class?: string;
}

const { variant, href, class: className } = Astro.props;
// Shared styles
const baseStyles = 'no-underline transition-colors duration-200';

// Variant-specific styles
const variants = {
  card: `text-base font-medium text-genkit-primary hover:text-foreground ${baseStyles}`,
  footer: `text-sm text-muted hover:text-foreground ${baseStyles}`,
  nav: `text-base font-normal text-muted hover:text-foreground ${baseStyles}`
} as const;
---

<a href={href} class={`${variants[variant]} ${className || ''}`}>
  <slot />
</a>