---
import Button from './Button.astro';
import Icon from './Icon.astro';
import LandingCodeBlock from './LandingCodeBlock.astro';
import { highlightCode } from './highlight-code';

type IconName = 'genkit-logo' | 'github' | 'discord' | 'nodejs' | 'typescript' | 'go' | 'python' | 'dart' | 'document' | 'search' | 'code';

interface Provider {
  name: string;
  id: string;
  code: string;
  html?: string;
  active?: boolean;
}

interface Language {
  name: string;
  id: string;
  status: string;
  active: boolean;
  icon: IconName;
  href: string;
  lang: string;
  providers: Provider[];
}

// Component configuration
const config = {
  title: "Genkit in your language",
  subtitle: "Get started with just a few lines of code.",
  ctaText: "Get Started"
};

// Language data with embedded code samples for different providers
