---
import { Image } from 'astro:assets';
import Button from './Button.astro';
import Link from './Link.astro';

import simpleChatbot from '../../assets/simple_chatbot.svg';
---

<section class="py-12 sm:py-20 px-6 md:pt-36">
  <div class="max-w-6xl mx-auto">
    <!-- Mobile: heading -> image -> buttons (natural document order)
         Desktop: image left, content right -->
    <div class="flex flex-col md:flex-row md:items-start gap-12">
      <!-- Image section - shows on desktop first (left side), hidden on mobile -->
      <div class="hidden md:block md:flex-1 space-y-4 md:order-1">
        <div class="rounded-2xl overflow-hidden backdrop-blur-sm bg-surface-elevated border border-border-muted">
          <Image src={simpleChatbot} alt="Simple Chatbot Interface" class="w-full h-auto" />
        </div>
      </div>

      <div class="md:w-1/3 md:shrink-0 space-y-8 pt-4 text-center md:text-left md:order-2">
        <!-- Heading section - always shows first on mobile and desktop -->
        <div class="space-y-6">
          <h1 class="text-3xl md:text-4xl font-bold leading-tight text-foreground">
            Genkit by Example
          </h1>
          <p class="text-base text-muted max-w-lg mx-auto md:mx-0">
            See how Genkit works with Firebase, Angular, Next.js and more in production-ready apps, with pre-built demos and code you can reuse.
          </p>
        </div>
        
        <!-- Image section - shows after heading on mobile, hidden on desktop (duplicate) -->
        <div class="md:hidden">
          <div class="rounded-2xl overflow-hidden backdrop-blur-sm bg-surface-elevated border border-border-muted">
            <img src="/assets/simple_chatbot.svg" alt="Simple Chatbot Interface" class="w-full h-auto" />
          </div>
        </div>
        
        <!-- Buttons section - shows last on mobile and desktop -->
        <div class="space-y-4 flex flex-col items-center md:items-start">
          <div class="pb-2">
            <Link variant="card" href="https://github.com/genkit-ai/genkit-by-example">
              Explore Samples Repository
            </Link>
          </div>
          <Button variant="secondary" href="https://examples.genkit.dev/">
            Launch Genkit by Example
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
