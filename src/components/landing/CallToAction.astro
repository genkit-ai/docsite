---
import Button from './Button.astro';
import Icon from './Icon.astro';
---

<section class="py-12 sm:py-20 px-6 text-center">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-center mx-auto mb-8">
      <Icon name="genkit-logo" size="lg" />
    </div>
    <h2 class="text-5xl md:text-7xl font-bold leading-tight text-foreground mb-6">Get Started Today</h2>
    <h3 class="text-lg font-semibold text-muted mb-8"></h3>
    <Button variant="primary" href="/docs/get-started">
      Get Started
    </Button>
  </div>
</section>