---
interface Props {
  variant?: 'primary' | 'secondary';
  size?: 'md' | 'lg';
  href: string;
  class?: string;
}

const { variant = 'primary', size = 'md', href, class: className = '' } = Astro.props;

const baseStyles = 'inline-flex items-center border rounded-full transition-colors duration-200';

const sizes = {
  md: 'px-6 py-2 text-sm min-h-[2.75rem]',
  lg: 'px-8 py-4 text-base min-h-[3.5rem]',
} as const;

const variants = {
  primary: 'bg-genkit-primary hover:bg-genkit-primary-hover border-genkit-primary text-black font-medium',
  secondary: 'bg-surface hover:bg-surface-elevated border-foreground text-foreground font-light',
} as const;

const buttonClasses = `${baseStyles} ${sizes[size]} ${variants[variant]} ${className}`;

---

<a class={buttonClasses} href={href}>
  <slot />
</a>
