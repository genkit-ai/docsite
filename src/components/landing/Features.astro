---
import Button from './Button.astro';
import Link from './Link.astro';
import { Image } from 'astro:assets';

import unifiedApis from '../../assets/unified_apis.svg';
import composableWorkflows from '../../assets/composable_workflows.svg';
import productionReady from '../../assets/production_ready.svg';

const features = [
  {
    title: 'Unified APIs for any model',
    body: 'Use GoogleAI, OpenAI, Claude, and Ollama through one SDK.',
    href: '/docs/models',
    icon: unifiedApis,
  },
  {
    title: 'Composable workflows',
    body: 'Structure chat, RAG, tool use, and agents with built-in primitives.',
    href: '/docs/flows',
    icon: composableWorkflows,
  },
  {
    title: 'Production-ready tools',
    body: 'Local dev, debugging UI, and deployment to Firebase, Cloud Run, or your stack.',
    href: '/docs/devtools',
    icon: productionReady,
  }
];
---

<section class="pt-4 sm:pt-8 px-4 text-center max-w-6xl mx-auto">
  <h2 class="text-3xl md:text-4xl font-bold leading-tight text-foreground mb-3">Simplified AI Integration</h2>
  <p class="text-base text-muted mb-4">The fastest way to build, test, and deploy real AI<br /> features into your apps.</p>

  <div class="grid md:grid-cols-3 gap-4 sm:gap-6 lg:gap-8 mt-4 sm:mt-8">
    {features.map((feature) => (
      <div class="rounded-xl p-4 sm:p-6 lg:p-8 xl:p-10 transition-colors text-left flex flex-col bg-surface-subtle border border-border-muted hover:opacity-80">
        <Image src={feature.icon} alt={feature.title} class="w-full mb-4 lg:mb-6" />
        <h3 class="text-lg font-semibold text-muted mb-3 lg:mb-4">{feature.title}</h3>
        <p class="text-sm leading-normal text-muted mb-4 lg:mb-6 flex-grow">{feature.body}</p>
        <Link variant="card" href={feature.href}>
          <span class="text-sm sm:text-base lg:text-lg">Learn more →</span>
        </Link>
      </div>
    ))}
  </div>

  <div class="mt-8 sm:mt-12">
    <Button variant="primary" href="https://github.com/genkit-ai/genkit-by-example">
      See Example Apps
    </Button>
  </div>
</section>
