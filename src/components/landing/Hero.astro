---
import Button from './Button.astro';
import Icon from './Icon.astro';
---

<section class="pt-8 px-6 text-center">
  <div class="max-w-4xl mx-auto">
    <div class="mt-12 sm:mt-20 mb-6 sm:mb-8">
      <!-- Mobile: Logo above text -->
      <div class="flex flex-col items-center gap-4 sm:hidden">
        <Icon name="genkit-logo" size="md" class="w-12 h-12" />
        <h1 class="text-5xl leading-tight tracking-tight text-foreground font-medium font-sans text-center">
          Build Powerful<br>
          Agentic Apps
        </h1>
      </div>
      
      <!-- Desktop: Logo inline -->
      <h1 class="hidden sm:block text-5xl lg:text-7xl leading-tight tracking-tight text-foreground font-medium font-sans text-center">
        Build Powerful<br>
        Agentic Apps
      </h1>
    </div>
    
    <p class="text-xl leading-normal text-muted mb-12 max-w-2xl mx-auto">
      Genkit is Google's open-source framework for building full-stack, AI-powered and agentic applications for any platform
    </p>
    
    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-center">
      <Button variant="primary" size="lg" href="/docs/get-started">
        Get Started
      </Button>
      <Button variant="secondary" size="lg" href="https://github.com/genkit-ai/genkit">
        View on Github
      </Button>
    </div>
  </div>
</section>
