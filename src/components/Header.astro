---
/**
 * Shared site header used both by the marketing landing page (rendered through
 * `src/layouts/Layout.astro`) and by every Starlight-rendered page (docs and
 * blog) via the `components.Header` override in `astro.config.mjs`.
 *
 * This component renders only the inner header content. The outer container
 * (background, height, sticky/fixed positioning, horizontal padding) is
 * provided by each context:
 *
 *   - Landing: wrapped in `<nav class="sticky ... bg-genkit-nav">` in
 *     `src/pages/index.astro`.
 *   - Starlight: wrapped in `<header class="header">` by Starlight's
 *     `Page.astro`. We override that element's styling in `tailwind.css` so
 *     it visually matches the marketing nav.
 *
 * Search, theme toggle, and language switcher rely on Starlight context
 * (`Astro.locals.t`, `Astro.locals.starlightRoute`, Pagefind data) and are
 * only rendered when a Starlight route is being served. The marketing landing
 * page therefore renders just the logo, primary links, and social icons.
 */
import Search from 'virtual:starlight/components/Search';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import config from 'virtual:starlight/user-config';

import Icon from './landing/Icon.astro';

/**
 * `Astro.locals.starlightRoute` is a defensive getter that throws on access
 * outside Starlight pages (the error itself recommends try/catch). We treat a
 * thrown access as "not a Starlight route" so this component can also be
 * rendered from the marketing landing page.
 */
let isStarlight = false;
try {
  isStarlight = Boolean(Astro.locals.starlightRoute);
} catch {
  isStarlight = false;
}

const pathname = Astro.url.pathname;
const isDocs = pathname.startsWith('/docs');
const isBlog =
  pathname.replace(/\/$/, '') === '/blog' || pathname.startsWith('/blog/');

const shouldRenderSearch =
  isStarlight &&
  (config.pagefind ||
    config.components.Search !== '@astrojs/starlight/components/Search.astro');
---

<div class="genkit-header flex items-center justify-between h-full text-foreground">
  <div class="flex items-center gap-6 min-w-0">
    <a href="/" class="flex items-center shrink-0" aria-label="Genkit home">
      <img
        src="/genkit_logo_horizontal_knockout.png"
        alt="Genkit"
        class="relative top-[-1.5px] h-16 w-auto"
      />
    </a>
    <div
      class="hidden font-medium sm:flex gap-6 *:text-base *:text-muted *:no-underline *:whitespace-nowrap *:transition-colors *:duration-200 *:hover:text-foreground *:aria-[current=page]:text-genkit-primary"
    >
      <a href="/docs/get-started" aria-current={isDocs ? 'page' : undefined}>Docs</a>
      <a href="/blog" aria-current={isBlog ? 'page' : undefined}>Blog</a>
    </div>
  </div>

  <div class="flex items-center gap-3">
    {shouldRenderSearch && (
      <div class="hidden md:flex">
        <Search />
      </div>
    )}
    <div
      class="flex items-center gap-1 *:inline-flex *:items-center *:justify-center *:w-8 *:h-8 *:text-muted *:transition-colors *:duration-200 *:hover:text-foreground"
    >
      <a href="https://github.com/genkit-ai/genkit" aria-label="GitHub">
        <Icon name="github" size="sm" />
      </a>
      <a href="https://discord.gg/qXt5zzQKpc" aria-label="Discord">
        <Icon name="discord" size="sm" />
      </a>
      <a href="https://x.com/genkitframework" aria-label="X">
        <Icon name="x" size="sm" />
      </a>
      <a href="https://www.linkedin.com/company/genkit" aria-label="LinkedIn">
        <Icon name="linkedin" size="sm" />
      </a>
      <a href="https://reddit.com/r/GenkitFramework" aria-label="Reddit">
        <Icon name="reddit" size="sm" />
      </a>
      <a href="/blog/rss.xml" aria-label="RSS feed">
        <Icon name="rss" size="sm" />
      </a>
    </div>
    {isStarlight && (
      <div class="border-l border-border-muted h-10 pl-4">
        <div class="hidden md:flex">
          <ThemeSelect />
        </div>
        <div class="hidden md:flex">
          <LanguageSelect />
        </div>
      </div>
    )}
  </div>
</div>
