---

import Search from 'virtual:starlight/components/Search';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import config from 'virtual:starlight/user-config';

import Icon from './landing/Icon.astro';

let isStarlight = false;
let hasSidebar = false;
try {
  const route = Astro.locals.starlightRoute;
  isStarlight = Boolean(route);
  hasSidebar = Boolean(route?.hasSidebar);
} catch {
  isStarlight = false;
  hasSidebar = false;
}

const hasMobileMenu = isStarlight && hasSidebar;
const responsiveShow = hasMobileMenu ? 'min-[50rem]:flex' : 'sm:flex';

const pathname = Astro.url.pathname;
const isDocs = pathname.startsWith('/docs');
const isBlog =
  pathname.replace(/\/$/, '') === '/blog' || pathname.startsWith('/blog/');

const shouldRenderSearch =
  isStarlight &&
  (config.pagefind ||
    config.components.Search !== '@astrojs/starlight/components/Search.astro');

type LocalIconName = 'github' | 'discord' | 'x' | 'linkedin' | 'reddit' | 'rss';

const socialIconMap: Record<string, LocalIconName> = {
  github: 'github',
  discord: 'discord',
  'x.com': 'x',
  twitter: 'x',
  linkedin: 'linkedin',
  reddit: 'reddit',
  rss: 'rss',
};

const socialLinks = (config.social ?? []).flatMap((entry) => {
  const name = socialIconMap[entry.icon];
  return name ? [{ ...entry, name }] : [];
});
---

<div class="genkit-header flex items-center justify-between h-full text-foreground">
  <div class="flex items-center gap-6 min-w-0">
    <a href="/" class="flex items-center shrink-0" aria-label="Genkit home">
      <img
        src="/genkit_logo_horizontal_knockout.png"
        alt="Genkit"
        class="relative top-[-1.5px] h-16 w-auto"
      />
    </a>
    <div
      class:list={[
        'hidden font-medium gap-6 *:text-base *:text-muted *:no-underline *:whitespace-nowrap *:transition-colors *:duration-200 *:hover:text-foreground *:aria-[current=page]:text-genkit-primary',
        responsiveShow,
      ]}
    >
      <a href="/docs/get-started" aria-current={isDocs ? 'page' : undefined}>Docs</a>
      <a href="/blog" aria-current={isBlog ? 'page' : undefined}>Blog</a>
    </div>
  </div>

  <div class="flex items-center gap-3">
    {shouldRenderSearch && (
      <div>
        <Search />
      </div>
    )}
    <div
      class:list={[
        'items-center gap-1 *:inline-flex *:items-center *:justify-center *:w-8 *:h-8 *:text-muted *:transition-colors *:duration-200 *:hover:text-foreground',
        hasMobileMenu ? 'hidden min-[50rem]:flex' : 'flex',
      ]}
    >
      {socialLinks.map(({ href, label, name }) => (
        <a href={href} aria-label={label}>
          <Icon name={name} size="sm" />
        </a>
      ))}
    </div>
    {isStarlight && (
      <div class="hidden min-[50rem]:block border-l border-border-muted h-10 pl-4">
          <ThemeSelect />
          <LanguageSelect />
      </div>
    )}
  </div>
</div>
