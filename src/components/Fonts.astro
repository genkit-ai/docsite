---
// Shared font wiring for the entire site. Registers @font-face declarations
// + the --font-google-* CSS variables referenced by genkit-theme.css.
// Above-the-fold body & display fonts are preloaded; mono is not.
import { Font } from 'astro:assets';
---

<Font cssVariable="--font-google-sans-text" preload />
<Font cssVariable="--font-google-sans" preload />
<Font cssVariable="--font-google-sans-mono" />
